# ============================================================================
# Mugutha FC Platform - Backend Configuration (.env.example)
# ============================================================================
# IMPORTANT: Copy this file to .env and fill in your actual values.
# Never commit .env with real secrets to git.

# ---- Database (Supabase) ----
# Sign up at https://supabase.com and create a project
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# ---- Server ----
PORT=5000

# ============================================================================
# WhatsApp Integration
# ============================================================================
# WHATSAPP_PROVIDER: Which provider to use
#   - "mock"   : Local mock provider (for demo/testing, no credentials needed)
#   - "twilio" : Twilio API (requires API_URL, API_TOKEN)
#   - other    : Custom provider
WHATSAPP_PROVIDER=mock

# WHATSAPP_API_URL: Provider endpoint URL
#   For mock: http://localhost:5000/internal/mock-whatsapp
#   For twilio: https://api.twilio.com/...
#   For other providers: https://your-provider-api.com/...
WHATSAPP_API_URL=http://localhost:5000/internal/mock-whatsapp

# WHATSAPP_API_TOKEN: Provider authentication token
#   For mock: ignored (mock provider doesn't authenticate)
#   For twilio: your Twilio Auth Token
WHATSAPP_API_TOKEN=your_whatsapp_token_here

# WHATSAPP_API_KEY: Provider authentication key (alternative to token)
WHATSAPP_API_KEY=your_whatsapp_key_here

# WHATSAPP_FROM_NUMBER: Sender phone number (your WhatsApp Business number)
#   Format: +254712345678 (country code + number)
WHATSAPP_FROM_NUMBER=+254712345678

# MOCK_WHATSAPP_DELAY_MS: Simulated network delay (milliseconds)
#   Default: 2000 (2 seconds)
#   Use to simulate cloud provider latency during testing
#   Example: 5000 = simulate 5 second delay
MOCK_WHATSAPP_DELAY_MS=2000

# ============================================================================
# Scheduler
# ============================================================================
# SCHEDULER_ENABLED: Enable/disable scheduled broadcast jobs
SCHEDULER_ENABLED=true

# ============================================================================
# Quick Start Guide
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY
# 3. For demo: keep WHATSAPP_PROVIDER=mock (no additional setup needed)
# 4. For production: set WHATSAPP_PROVIDER to your provider and add credentials
# 5. Run: npm install && npm run dev
